  "ingredients": [
    "250 g gemischtes Hackfleisch",
    "4 Stück Weizentortillas",
    "380 g schwarze Bohnen",
    "20 ml BBQ-Soße",
    "6 g Gewürzmischung „Hello Piri Piri“",
    "50 ml Buttermilch-Zitronen-Dressing",
    "1 Stück Salatherz (Romana)",
    "1 Stück Zwiebel",
    "35 g Tomatenmark",
    "nach Geschmack Salz",
    "nach Geschmack Pfeffer"
  ],
  "lastUsed": null,
  "instructions": [
    {
      "title": "Schritt 1",
      "text": "Zwiebel halbieren und in feine Streifen schneiden. Schwarze Bohnen durch ein Sieb abgießen und mit Wasser abspülen. Eine große Pfanne ohne Fettzugabe erhitzen. Hackfleisch und Zwiebelstreifen darin 4 – 5 Min. anbraten. In der Zwischenzeit mit dem Rezept fortfahren.",
      "imageUrl": "/images/hellofresh/bbq-burritos-mit-hackfleisch-step-1.jpg"
    },
    {
      "title": "Schritt 2",
      "text": "Salatherz in feine Streifen schneiden. In einer großen Schüssel Buttermilch-Zitronen-Dressing und Salatstreifen vermengen. Tomatenmark, schwarze Bohnen, BBQ Soße und „Hello Piri Piri“ hinzugeben und 1 weitere Min. braten. Mit Salz* und Pfeffer* abschmecken.",
      "imageUrl": "/images/hellofresh/bbq-burritos-mit-hackfleisch-step-2.jpg"
    },
    {
