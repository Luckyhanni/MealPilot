# =========================================================
# MealPilot .gitignore
# Node.js + React/Vite + Express + Supabase/Render
# =========================================================


# ---------------------------------------------------------
# Dependencies
# ---------------------------------------------------------
node_modules/
backend/node_modules/
frontend/node_modules/


# ---------------------------------------------------------
# Build output
# ---------------------------------------------------------
dist/
build/
backend/dist/
frontend/dist/
frontend/.vite/


# ---------------------------------------------------------
# Environment variables / secrets
# IMPORTANT:
# Do not commit Supabase keys, Render secrets, API keys, etc.
# ---------------------------------------------------------
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# Vite local env files
*.local


# ---------------------------------------------------------
# Local MealPilot runtime data
# Keep examples/templates if you create them.
# Online version should store real data in Supabase.
# ---------------------------------------------------------
backend/data/history.json
backend/data/pantry.json
backend/data/shoppingState.json
backend/data/settings.local.json
backend/data/users.json
backend/data/users.local.json
backend/data/recipeHistory.json

# Optional: ignore local imported HelloFresh images
# because online hosting should store image URLs or use Supabase Storage.
frontend/public/images/hellofresh/

# Keep recipe base data only if you want it public.
# If your recipes/links/settings should stay private, uncomment this:
# backend/data/recipes.json
# backend/data/settings.json


# ---------------------------------------------------------
# Logs
# ---------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# ---------------------------------------------------------
# Runtime / cache
# ---------------------------------------------------------
.cache/
.tmp/
temp/
tmp/
*.pid
*.seed
*.pid.lock


# ---------------------------------------------------------
# TypeScript
# ---------------------------------------------------------
*.tsbuildinfo
backend/*.tsbuildinfo
frontend/*.tsbuildinfo


# ---------------------------------------------------------
# Test / coverage
# ---------------------------------------------------------
coverage/
.nyc_output/
test-results/
playwright-report/


# ---------------------------------------------------------
# Package manager caches
# ---------------------------------------------------------
.npm/
.pnpm-store/
.yarn/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz


# ---------------------------------------------------------
# OS files
# ---------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini


# ---------------------------------------------------------
# Editor / IDE
# ---------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?


# ---------------------------------------------------------
# Render / deployment local files
# ---------------------------------------------------------
.render/
.render-build/


# ---------------------------------------------------------
# Optional local archives
# ---------------------------------------------------------
*.zip
*.rar
*.7z
